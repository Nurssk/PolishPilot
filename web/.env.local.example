GEMINI_API_KEY=replace-with-your-google-ai-studio-key

# Polar billing (LookRight Pro) — see web/POLAR_SETUP.md. Do not commit real values.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_SUCCESS_URL=https://polish-pilot.vercel.app/billing/success
POLAR_CANCEL_URL=https://polish-pilot.vercel.app/billing/cancel
APP_BASE_URL=https://polish-pilot.vercel.app
POLAR_SERVER=production

# Email login
# Local dev can omit RESEND_API_KEY; /api/auth/email/start returns debugCode.
AUTH_EMAIL_SECRET=local-dev-change-me
RESEND_API_KEY=
AUTH_EMAIL_FROM=PolishPilot <login@your-domain.com>
AUTH_EMAIL_DEBUG_CODE=true

# Firebase / Firestore usage tracking
FIREBASE_PROJECT_ID=humanize-ui
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY:
FIREBASE_SERVICE_ACCOUNT_JSON=
