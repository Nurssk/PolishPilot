# Existing
GEMINI_API_KEY=replace-with-your-google-ai-studio-key

# Polar billing (LookRight Pro)
# Do NOT commit real values. In production these must be set as Vercel
# Environment Variables (Project Settings -> Environment Variables).
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_SUCCESS_URL=https://polish-pilot.vercel.app/billing/success
POLAR_CANCEL_URL=https://polish-pilot.vercel.app/billing/cancel
APP_BASE_URL=https://polish-pilot.vercel.app

# Email login
# AUTH_EMAIL_SECRET signs 6-digit email codes and extension session tokens.
# Use a long random value in production.
AUTH_EMAIL_SECRET=
# Optional in local dev. Required in production if email login should send real email.
RESEND_API_KEY=
AUTH_EMAIL_FROM=PolishPilot <login@your-domain.com>
# Local/testing only. Never enable in production.
AUTH_EMAIL_DEBUG_CODE=false

# Optional: "production" (default) or "sandbox" for Polar's test environment.
POLAR_SERVER=production

# Firebase Auth (server-side ID-token verification)
# ID-token verification needs ONLY the project ID + Google's public keys — no
# service account. CLIENT_EMAIL / PRIVATE_KEY are optional and only needed for
# future privileged admin operations. Never commit a real private key.
FIREBASE_PROJECT_ID=humanize-ui
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
